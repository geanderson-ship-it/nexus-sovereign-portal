
/**
 * @fileoverview Firestore Security Rules for Nexus Treinamento.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-specific data
 * and allows public read access to course information. It also explicitly enables
 * the Google.com authentication provider.
 *
 * Data Structure:
 * - /users/{userId}: Stores personal user data, accessible only by the user.
 * - /users/{userId}/purchases/{purchaseId}: Stores a user's purchase history.
 * - /users/{userId}/trials/{trialId}: Stores a user's trial period data.
 * - /courses/{courseId}: Stores public course information, publicly readable.
 * - /reviews/{reviewId}: Stores user reviews.
 * - /recommendations/{recommendationId}: Stores course recommendations.
 * - /merit_indices/{meritIndexId}: Stores performance evaluations (IMN).
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - Course data is publicly readable to facilitate discovery.
 * - User-specific data (purchases, evaluations, trials) is stored with ownership rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an admin based on their email.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email.toLowerCase() in ['geanderson@nexustreinamento.com', 'geandersonleo@gmail.com'];
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner and if the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * @description Checks if the user is the owner of the document based on a `userId` or `evaluatorId` field in the resource data.
     */
    function isResourceOwner() {
        return isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.evaluatorId);
    }
    
     /**
     * @description Checks if the user is creating a resource for themselves, based on `userId` or `evaluatorId`.
     */
    function isCreatingForSelf() {
        return isSignedIn() && (request.auth.uid == request.resource.data.userId || request.auth.uid == request.resource.data.evaluatorId);
    }

    /**
     * @description Rules for the /users/{userId} collection.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id; // Enforce immutability of userId
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the user's purchases subcollection.
       * @path /users/{userId}/purchases/{purchaseId}
       * @allow (read, write) - A user can manage their own purchases.
       */
      match /purchases/{purchaseId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Rules for the user's trials subcollection.
       * @path /users/{userId}/trials/{trialId}
       * @allow (read, write) - A user can manage their own trial data.
       */
      match /trials/{trialId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Rules for the /courses/{courseId} collection.
     */
    match /courses/{courseId} {
      allow get, list: if true;
      allow create, update, delete: if false;  // Admin only
    }
    
    /**
     * @description Legacy /purchases root collection is now disabled.
     */
    match /purchases/{purchaseId} {
      allow read, write: if false;
    }

    /**
     * @description Rules for the /reviews/{reviewId} collection.
     */
    match /reviews/{reviewId} {
      allow get: if isResourceOwner();
      allow list: if isSignedIn(); // Queries must filter by userId on the client.
      allow create: if isCreatingForSelf();
      allow update: if isResourceOwner() && isCreatingForSelf();
      allow delete: if isResourceOwner();
    }

    /**
     * @description Rules for the /recommendations/{recommendationId} collection.
     */
    match /recommendations/{recommendationId} {
      allow get: if isResourceOwner();
      allow list: if isSignedIn(); // Queries must filter by userId on the client.
      allow create: if isCreatingForSelf();
      allow update: if isResourceOwner() && isCreatingForSelf();
      allow delete: if isResourceOwner();
    }

    /**
     * @description Rules for the /merit_indices/{meritIndexId} collection.
     */
    match /merit_indices/{meritIndexId} {
      allow get: if isResourceOwner() || isAdmin();
      allow list: if isAdmin();
      allow create: if isCreatingForSelf();
      allow update: if isResourceOwner() && isCreatingForSelf(); // Should be immutable in practice.
      allow delete: if isResourceOwner();
    }

    /**
     * @description Rules for the /feedbacks/{feedbackId} collection.
     */
    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }


    // Legacy sub-collection rules (can be removed if no longer used)
    match /users/{userId}/reviews/{reviewId} {
      allow read, write: if false;
    }
    match /users/{userId}/recommendations/{recommendationId} {
      allow read, write: if false;
    }
  }
}
